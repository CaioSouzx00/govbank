# ============================================================================
# GOVBANK CORE - ENVIRONMENT VARIABLES
# Copie este arquivo para .env e ajuste os valores conforme necessário
# ============================================================================

# ===== DATABASE =====
DB_HOST=localhost
DB_PORT=5433
DB_NAME=govbank_core
DB_USER=govbank_app
DB_PASSWORD=GovBank@2026!

# Para produção, use senhas mais fortes:
# DB_PASSWORD=$(openssl rand -base64 32)

# ===== API (JAVA/SPRING BOOT) =====
API_PORT=8080
API_PROFILE=dev
# Opções: dev, docker, prod

# ===== SECURITY =====
# IMPORTANTE: Altere em produção!
JWT_SECRET=your-secret-key-here-min-32-chars-change-in-production
JWT_EXPIRATION=86400000
# 86400000 ms = 24 horas

# ===== COBOL =====
COBOL_DATA_PATH=/app/core/data
COBOL_LOG_LEVEL=INFO
# Opções: DEBUG, INFO, WARN, ERROR

# ===== AUDIT =====
AUDIT_ENABLED=true
AUDIT_LOG_PATH=/app/logs/audit

# ===== OBSERVABILITY (OPCIONAL) =====
PROMETHEUS_ENABLED=false
GRAFANA_ENABLED=false

# ===== PGADMIN (DESENVOLVIMENTO) =====
PGADMIN_EMAIL=admin@govbank.local
PGADMIN_PASSWORD=admin

# ===== DOCKER NETWORK =====
NETWORK_SUBNET=172.28.0.0/16

# ===== PERFORMANCE TUNING =====
# Java Heap Size
JAVA_XMS=512m
JAVA_XMX=1024m

# PostgreSQL
PG_SHARED_BUFFERS=256MB
PG_EFFECTIVE_CACHE_SIZE=1GB
PG_MAX_CONNECTIONS=200

# ===== TIMEZONE =====
TZ=America/Sao_Paulo

# ===== LOGS =====
LOG_LEVEL=INFO
LOG_FILE_MAX_SIZE=100MB
LOG_FILE_MAX_HISTORY=30

# ===== BACKUP (OPCIONAL) =====
BACKUP_ENABLED=false
BACKUP_SCHEDULE="0 2 * * *"
# Formato cron: diariamente às 2h da manhã
BACKUP_RETENTION_DAYS=7