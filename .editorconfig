# ============================================================================
# GOVBANK CORE - EDITOR CONFIG
# Garante consistência de código entre editores
# ============================================================================

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.{cbl,cpy,jcl}]
indent_size = 4
charset = iso-8859-1

[Makefile]
indent_style = tab